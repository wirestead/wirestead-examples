{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "fetchcontent",
      "displayName": "FetchContent",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "WIRESTEAD_EXAMPLES_USE_FETCHCONTENT": "ON"
      }
    },
    {
      "name": "vcpkg",
      "displayName": "vcpkg",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "WIRESTEAD_EXAMPLES_USE_FETCHCONTENT": "OFF"
      }
    },
    {
      "name": "installed",
      "displayName": "Installed Wirestead package",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_PREFIX_PATH": "$env{WIRESTEAD_INSTALL_PREFIX}",
        "WIRESTEAD_EXAMPLES_USE_FETCHCONTENT": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "fetchcontent",
      "configurePreset": "fetchcontent"
    },
    {
      "name": "vcpkg",
      "configurePreset": "vcpkg"
    },
    {
      "name": "installed",
      "configurePreset": "installed"
    }
  ]
}
